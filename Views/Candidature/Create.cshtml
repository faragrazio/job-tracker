@model JobTracker.Models.Candidatura

@{
    ViewData["Title"] = "Nuova candidatura";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-plus-lg"></i> Nuova candidatura</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Riga 1: Azienda + Ruolo -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Azienda" class="form-label">Azienda *</label>
                            <input asp-for="Azienda" class="form-control" placeholder="Es. Microsoft">
                            <span asp-validation-for="Azienda" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Ruolo" class="form-label">Ruolo *</label>
                            <input asp-for="Ruolo" class="form-control" placeholder="Es. .NET Developer">
                            <span asp-validation-for="Ruolo" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Riga 2: Città + Modalità -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Citta" class="form-label">Città</label>
                            <input asp-for="Citta" class="form-control" placeholder="Es. Milano">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Modalita" class="form-label">Modalità</label>
                            <select asp-for="Modalita" class="form-select">
                                <option value="">Seleziona...</option>
                                <option value="In sede">In sede</option>
                                <option value="Ibrido">Ibrido</option>
                                <option value="Full remote">Full remote</option>
                            </select>
                        </div>
                    </div>

                    <!-- Riga 3: Fonte + Data candidatura -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Fonte" class="form-label">Fonte</label>
                            <select asp-for="Fonte" class="form-select">
                                <option value="">Seleziona...</option>
                                <option value="LinkedIn">LinkedIn</option>
                                <option value="Indeed">Indeed</option>
                                <option value="Sito aziendale">Sito aziendale</option>
                                <option value="Agenzia">Agenzia</option>
                                <option value="Passaparola">Passaparola</option>
                                <option value="Altro">Altro</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DataCandidatura" class="form-label">Data candidatura *</label>
                            <input asp-for="DataCandidatura" type="date" class="form-control">
                            <span asp-validation-for="DataCandidatura" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Riga 4: Stato + RAL -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Stato" class="form-label">Stato</label>
                            <select asp-for="Stato" class="form-select">
                                <option value="Inviata">Inviata</option>
                                <option value="Visualizzata">Visualizzata</option>
                                <option value="Colloquio">Colloquio</option>
                                <option value="Rifiutata">Rifiutata</option>
                                <option value="Offerta">Offerta</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RALIndicata" class="form-label">RAL indicata</label>
                            <input asp-for="RALIndicata" class="form-control" placeholder="Es. 28.000€">
                        </div>
                    </div>

                    <!-- Riga 5: Stack richiesto -->
                    <div class="mb-3">
                        <label asp-for="StackRichiesto" class="form-label">Stack richiesto</label>
                        <input asp-for="StackRichiesto" class="form-control" 
                               placeholder="Es. C#, ASP.NET MVC, JavaScript, MySQL">
                    </div>

                    <!-- Riga 6: Link offerta -->
                    <div class="mb-3">
                        <label asp-for="LinkOfferta" class="form-label">Link offerta</label>
                        <input asp-for="LinkOfferta" type="url" class="form-control" 
                               placeholder="https://...">
                    </div>

                    <!-- Riga 7: Date risposta e colloquio -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="DataRisposta" class="form-label">Data risposta</label>
                            <input asp-for="DataRisposta" type="date" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DataColloquio" class="form-label">Data colloquio</label>
                            <input asp-for="DataColloquio" type="date" class="form-control">
                        </div>
                    </div>

                    <!-- Riga 8: Note -->
                    <div class="mb-3">
                        <label asp-for="Note" class="form-label">Note</label>
                        <textarea asp-for="Note" class="form-control" rows="3" 
                                  placeholder="Appunti, contatti, impressioni..."></textarea>
                    </div>

                    <!-- Pulsanti -->
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Torna alla lista
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-lg"></i> Salva candidatura
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>