@model JobTracker.Models.Candidatura
@{
    ViewData["Title"] = "Dettaglio Candidatura";
}

<div class="container py-4" style="max-width:700px">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary">← Indietro</a>
        <h3 class="mb-0 fw-bold">📄 @Model.Azienda — @Model.Ruolo</h3>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <div class="row g-3">
                @{
                    void Row(string label, string? value) {
                        if (!string.IsNullOrEmpty(value)) {
                            <div class="col-md-6">
                                <div class="text-muted small">@label</div>
                                <div class="fw-semibold">@value</div>
                            </div>
                        }
                    }
                }
                @{ Row("Azienda", Model.Azienda); }
                @{ Row("Ruolo", Model.Ruolo); }
                @{ Row("Città", Model.Citta); }
                @{ Row("Modalità", Model.Modalita); }
                @{ Row("Fonte", Model.Fonte); }
                @{ Row("Stato", Model.Stato); }
                @{ Row("RAL Indicata", Model.RALIndicata); }
                @{ Row("Stack Richiesto", Model.StackRichiesto); }
                @{ Row("Data Candidatura", Model.DataCandidatura.ToString("dd/MM/yyyy")); }
                @{ Row("Data Risposta", Model.DataRisposta?.ToString("dd/MM/yyyy")); }
                @{ Row("Data Colloquio", Model.DataColloquio?.ToString("dd/MM/yyyy")); }

                @if (!string.IsNullOrEmpty(Model.LinkOfferta))
                {
                    <div class="col-12">
                        <div class="text-muted small">Link Offerta</div>
                        <a href="@Model.LinkOfferta" target="_blank" class="fw-semibold">
                            🔗 Apri offerta
                        </a>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <div class="col-12">
                        <div class="text-muted small">Note</div>
                        <div class="fw-semibold">@Model.Note</div>
                    </div>
                }
            </div>

            <div class="d-flex gap-2 mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" 
                   class="btn btn-primary">✏️ Modifica</a>
                <a asp-action="Index" class="btn btn-outline-secondary">← Lista</a>
            </div>
        </div>
    </div>
</div>