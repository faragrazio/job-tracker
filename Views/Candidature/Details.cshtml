@model JobTracker.Models.Candidatura

@{
    ViewData["Title"] = "Dettaglio candidatura";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-eye"></i> @Model.Azienda — @Model.Ruolo</h5>
                @{
                    var badgeClass = Model.Stato switch
                    {
                        "Inviata" => "bg-info",
                        "Visualizzata" => "bg-secondary",
                        "Colloquio" => "bg-warning text-dark",
                        "Rifiutata" => "bg-danger",
                        "Offerta" => "bg-success",
                        _ => "bg-light text-dark"
                    };
                }
                <span class="badge @badgeClass fs-6">@Model.Stato</span>
            </div>
            <div class="card-body">

                <!-- Informazioni principali -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted">Azienda</h6>
                        <p class="fs-5"><strong>@Model.Azienda</strong></p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted">Ruolo</h6>
                        <p class="fs-5">@Model.Ruolo</p>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-4">
                        <h6 class="text-muted">Città</h6>
                        <p>@(Model.Citta ?? "—")</p>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-muted">Modalità</h6>
                        <p>@(Model.Modalita ?? "—")</p>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-muted">Fonte</h6>
                        <p>@(Model.Fonte ?? "—")</p>
                    </div>
                </div>

                <hr />

                <!-- Date -->
                <div class="row mb-4">
                    <div class="col-md-4">
                        <h6 class="text-muted">Data candidatura</h6>
                        <p>@Model.DataCandidatura.ToString("dd/MM/yyyy")</p>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-muted">Data risposta</h6>
                        <p>@(Model.DataRisposta?.ToString("dd/MM/yyyy") ?? "—")</p>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-muted">Data colloquio</h6>
                        <p>@(Model.DataColloquio?.ToString("dd/MM/yyyy") ?? "—")</p>
                    </div>
                </div>

                <hr />

                <!-- Dettagli tecnici -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted">RAL indicata</h6>
                        <p>@(Model.RALIndicata ?? "—")</p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted">Stack richiesto</h6>
                        <p>@(Model.StackRichiesto ?? "—")</p>
                    </div>
                </div>

                <!-- Link offerta -->
                @if (!string.IsNullOrEmpty(Model.LinkOfferta))
                {
                    <div class="mb-4">
                        <h6 class="text-muted">Link offerta</h6>
                        <a href="@Model.LinkOfferta" target="_blank" class="text-decoration-none">
                            <i class="bi bi-box-arrow-up-right"></i> @Model.LinkOfferta
                        </a>
                    </div>
                }

                <!-- Note -->
                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <div class="mb-4">
                        <h6 class="text-muted">Note</h6>
                        <div class="bg-light rounded p-3">
                            @Model.Note
                        </div>
                    </div>
                }

                <!-- Pulsanti azione -->
                <hr />
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Torna alla lista
                    </a>
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                            <i class="bi bi-pencil"></i> Modifica
                        </a>
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Sei sicuro di voler eliminare questa candidatura?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Elimina
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>