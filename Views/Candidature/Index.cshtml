@model List<JobTracker.Models.Candidatura>

@{
    ViewData["Title"] = "Le mie candidature";
}

<!-- ==================== CARD RIASSUNTIVE DASHBOARD ==================== -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card card-dashboard text-white bg-primary">
            <div class="card-body text-center">
                <h5 class="card-title">Totali</h5>
                <h2>@ViewBag.Totale</h2>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card card-dashboard text-white bg-info">
            <div class="card-body text-center">
                <h5 class="card-title">Inviate</h5>
                <h2>@ViewBag.Inviate</h2>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card card-dashboard text-white bg-warning">
            <div class="card-body text-center">
                <h5 class="card-title">Colloqui</h5>
                <h2>@ViewBag.Colloqui</h2>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card card-dashboard text-white bg-danger">
            <div class="card-body text-center">
                <h5 class="card-title">Rifiutate</h5>
                <h2>@ViewBag.Rifiutate</h2>
            </div>
        </div>
    </div>
</div>

<!-- ==================== GRAFICI HIGHCHARTS ==================== -->
<div class="row g-3 mb-4">
    <div class="col-md-5">
        <div class="card card-grafico">
            <div class="card-header">
                <i class="bi bi-pie-chart-fill"></i> Distribuzione per stato
            </div>
            <div class="card-body">
                <div id="chart-stato" style="height: 280px;"></div>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card card-grafico">
            <div class="card-header">
                <i class="bi bi-graph-up"></i> Candidature nel tempo
            </div>
            <div class="card-body">
                <div id="chart-tempo" style="height: 280px;"></div>
            </div>
        </div>
    </div>
</div>

<!-- ==================== FILTRI E RICERCA ==================== -->
<div class="card card-filtri mb-4">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Filtra per stato</label>
                <select name="stato" class="form-select form-select-sm">
                    <option value="">Tutti gli stati</option>
                    <option value="Inviata" selected="@(ViewBag.Stato == "Inviata")">Inviata</option>
                    <option value="Visualizzata" selected="@(ViewBag.Stato == "Visualizzata")">Visualizzata</option>
                    <option value="Colloquio" selected="@(ViewBag.Stato == "Colloquio")">Colloquio</option>
                    <option value="Rifiutata" selected="@(ViewBag.Stato == "Rifiutata")">Rifiutata</option>
                    <option value="Offerta" selected="@(ViewBag.Stato == "Offerta")">Offerta</option>
                </select>
            </div>
            <div class="col-md-5">
                <label class="form-label">Cerca per azienda o ruolo</label>
                <input type="text" name="cerca" class="form-control form-control-sm"
                       value="@ViewBag.Cerca" placeholder="Es. Microsoft, Backend Developer...">
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary btn-sm me-2">
                    <i class="bi bi-search"></i> Filtra
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Reset</a>
            </div>
        </form>
    </div>
</div>

<!-- ==================== MESSAGGIO DI SUCCESSO ==================== -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ==================== PULSANTE AGGIUNGI + TABELLA ==================== -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Lista candidature</h5>
    <a asp-action="Create" class="btn btn-success btn-sm">
        <i class="bi bi-plus-lg"></i> Nuova candidatura
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        Nessuna candidatura trovata. Clicca "Nuova candidatura" per aggiungerne una.
    </div>
}
else
{
    <div class="card card-tabella">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Azienda</th>
                        <th>Ruolo</th>
                        <th>Città</th>
                        <th>Modalità</th>
                        <th>Data</th>
                        <th>Stato</th>
                        <th class="text-end">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr id="row-@c.Id">
                            <td><strong>@c.Azienda</strong></td>
                            <td>@c.Ruolo</td>
                            <td>@c.Citta</td>
                            <td>@c.Modalita</td>
                            <td>@c.DataCandidatura.ToString("dd/MM/yyyy")</td>
                            <td>
                                @{
                                    var badgeClass = c.Stato switch
                                    {
                                        "Inviata" => "bg-info",
                                        "Visualizzata" => "bg-secondary",
                                        "Colloquio" => "bg-warning text-dark",
                                        "Rifiutata" => "bg-danger",
                                        "Offerta" => "bg-success",
                                        _ => "bg-light text-dark"
                                    };
                                }
                                <span class="badge @badgeClass">@c.Stato</span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-primary btn-azioni" title="Dettagli">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-warning btn-azioni" title="Modifica">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-azioni"
                                        title="Elimina"
                                        onclick="eliminaCandidatura(@c.Id, '@c.Azienda')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- ==================== SCRIPT ==================== -->
@section Scripts {
    <!-- Highcharts CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highcharts/11.4.1/highcharts.min.js"></script>

    <!-- File JS del progetto -->
    <script src="~/js/charts.js" asp-append-version="true"></script>
    <script src="~/js/candidature.js" asp-append-version="true"></script>

    <!-- Token CSRF per le chiamate AJAX -->
    @Html.AntiForgeryToken()
}
