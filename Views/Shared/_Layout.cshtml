<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — JobTracker</title>

    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- CSS personalizzato -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Candidature" asp-action="Index">
                <i class="bi bi-briefcase-fill"></i> JobTracker
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Candidature" asp-action="Index">
                            <i class="bi bi-list-ul"></i> Candidature
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Candidature" asp-action="Create">
                            <i class="bi bi-plus-lg"></i> Nuova
                        </a>
                    </li>
                </ul>
                <span class="navbar-text text-light">
                    <i class="bi bi-person-circle"></i> Graziano Faraone
                </span>
            </div>
        </div>
    </nav>

    <!-- Contenuto principale -->
    <main class="container pb-5">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-light text-center py-3 mt-auto">
        <div class="container">
            <small>&copy; @DateTime.Now.Year JobTracker — Progetto portfolio di Graziano Faraone</small>
        </div>
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Sezione per script aggiuntivi delle singole view -->
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>